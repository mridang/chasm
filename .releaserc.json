{
  "branches": [
    "master"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "semantic-release-cargo",
    [
      "@mridang/semantic-release-oci",
      {
        "dockerRegistry": "docker.io",
        "dockerProject": "mridang",
        "dockerImage": "chasm",
        "dockerTags": ["latest", "{{major}}", "{{version}}"],
        "dockerTimeout": 3600000,
        "dockerBake": {
          "file": "docker-bake.hcl",
          "group": "release",
          "imageTarget": "image"
        }
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "dist/linux_amd64/chasm-server", "name": "chasm-server-linux-amd64", "label": "chasm-server (linux/amd64)" },
          { "path": "dist/linux_arm64/chasm-server", "name": "chasm-server-linux-arm64", "label": "chasm-server (linux/arm64)" }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "Cargo.toml",
          "Cargo.lock",
          "crates/*/Cargo.toml"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
